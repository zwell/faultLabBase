# FaultLab 本地环境变量示例
# 复制本文件为仓库根目录的 `.env` 和/或 `webapp/.env`（任选其一或两者；后者可覆盖前者未设置的项）。
# 已在 shell（如 ~/.zshrc）中 export 的变量不会被这些文件覆盖。

# --- Web 面板（webapp/server.js）问题分析 / LLM ---
# DeepSeek（默认 LLM_PROVIDER=deepseek）
DEEPSEEK_API_KEY=

# 或通用 Key（两种提供商均可回退使用）
# LLM_API_KEY=

# 可选：OpenAI
# LLM_PROVIDER=openai
# OPENAI_API_KEY=

# LLM_MODEL=
# LLM_API_BASE=
# LLM_TIMEOUT_MS=
